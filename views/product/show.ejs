<% layout('layouts/boilerplate') %>

<div class="container mt-4">
    <div class="row">

        <!-- Product Card -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow mx-auto" style="width: 18rem;">
                <img 
                    src="<%= foundProduct.img %>" 
                    class="card-img-top" 
                    alt="<%= foundProduct.name %>"
                    style="height:180px; object-fit:cover;"
                >
                <div class="card-body">
                    <h6 class="card-title"><%= foundProduct.name %></h6>
                    <p>₹ <%= foundProduct.price %></p>
                    <p><%= foundProduct.desc %></p>

                    <a href="/products/<%= foundProduct._id %>" class="btn btn-sm btn-primary">
                        Add to Cart
                    </a>
                    <a href="/cart/add/<%= foundProduct._id %>" class="btn btn-sm btn-info">
                        Buy Product
                    </a>
                </div>
            </div>
        </div>

        <!-- Review Section -->
        <div class="col-lg-6">
            <h1 class="display-6">Leave a Review</h1>

            <form action="/products/<%= foundProduct._id %>/reviews" method="POST">

                <fieldset class="starability-basic">
                    <legend>Rating:</legend>

                    <input type="radio" id="first-rate1" name="rating" value="1" checked />
                    <label for="first-rate1">1 star</label>

                    <input type="radio" id="first-rate2" name="rating" value="2" />
                    <label for="first-rate2">2 stars</label>

                    <input type="radio" id="first-rate3" name="rating" value="3" />
                    <label for="first-rate3">3 stars</label>

                    <input type="radio" id="first-rate4" name="rating" value="4" />
                    <label for="first-rate4">4 stars</label>

                    <input type="radio" id="first-rate5" name="rating" value="5" />
                    <label for="first-rate5">5 stars</label>
                </fieldset>

                <div class="mb-3 mt-2">
                    <label for="comment">Comment:</label>
                    <textarea name="comment" rows="3" id="comment" class="form-control"></textarea>
                </div>

                <button type="submit" class="btn btn-success btn-sm">
                    Submit Review
                </button>
            </form>

            <!-- Reviews List -->
            <div class="mt-4">
                <% for(let review of foundProduct.reviews){ %>

                    <div class="card mt-3 p-2">

                        <% if(review.createdAt){ %>
                            <small><%= review.createdAt.toLocaleDateString() %></small>
                        <% } %>

                        <p class="starability-result" data-rating="<%= review.rating %>">
                            Rated: <%= review.rating %> stars
                        </p>

                        <p><strong>Comment:</strong> <%= review.comment %></p>

                    </div>

                <% } %>
            </div>

        </div>

    </div>
</div>