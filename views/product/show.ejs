<!-- include boiler plate -->
<% layout('layouts/boilerplate') %>
<!-- include partials -->
<% include('../partials/header') %>
<div class="container mt-4">
    <div class="row">
            <div class="col-lg-6 col-md-4 col-sm-6 mb-4">
                <div class="card shadow mx-auto" style="width: 18rem;">
                    <img 
                        src="<%= foundProduct.img %>" 
                        class="card-img-top" 
                        alt="<%= foundProduct.name %>"
                        style="height:180px; object-fit:cover;"
                    >
                    <div class="card-body">
                        <h6 class="card-title">
                            <%= foundProduct.name %>
                        </h6>
                        <p class="card-title">
                            ₹ <%= foundProduct.price %>
                        </p>
                        <p class="card-text">
                            <%= foundProduct.desc %>
                        </p>
                        <a href="/products/<%= foundProduct._id %>" class="btn btn-sm btn-primary">
                            Add to Cart
                        </a>
                        <a href="/cart/add/<%= foundProduct._id %>" class="btn btn-sm btn-info">
                            Buy Product
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h1 class="display-4">Leave a Review</h1>
                <form action="/products/<%= foundProduct._id %>/reviews" method="POST">
                    <div >
                        <fieldset class="starability-basic">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
                    </div>
                    <div class="mb-3">
                        <label for="comment">Comment:</label>
                        <textarea name="comment" rows="3" id="comment" class="form-control"></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-success">Submit Review</button>
                </form>
                <div class="my-3">
                    <% for(let review of foundProduct.reviews){ %>
                            <div class="card mt-3">
                                <p class="card-title mx-2">
                                    <% if(review.createdAt){ %>
                                        <p><%= review.createdAt.toLocaleDateString() %></p>
                                    <% } %>
                                </p>
  <p class="starability-result" data-rating="<%= review.rating %>">
    Rated: <%= review.rating %> stars
  </p>
                                    <div class="card-body">
                                        <p class="card-text">Comment: <%= review.comment %></p>
                                        <a href="#" class="btn btn-primary">Go somewhere</a>
                                    </div>
                                </div>
                        </div>
                    <% } %>
                </div>
            </div>
    </div>
</div> 